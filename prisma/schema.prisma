generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  runtime             = "cloudflare"
  importFileExtension = "ts"
}

generator client_node {
  provider            = "prisma-client"
  output              = "../prisma/generated/node"
  runtime             = "nodejs"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  UX_UI
  SAAS
  SCIENCE
  ARCHITECTURE
  ENGINEERING
  DATA
  MARKETING
  CONTENT
  RESEARCH
  DEVOPS
  MOBILE
  GAME_DEV
  EDUCATION
  LEGAL
  FINANCE
  HEALTHCARE
  PRODUCT
  DESIGN
  OTHER
}

enum PostKind {
  WORKFLOW
  PROMPT
  HARNESS
  SKILL
  SETUP
  MCP
  PLAYBOOK
  TEMPLATE
  OTHER
}

model User {
  id              String    @id
  name            String
  email           String
  emailVerified   Boolean   @default(false)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  termsAcceptedAt DateTime?
  termsVersion    String?
  privacyVersion  String?
  sessions        Session[]
  accounts        Account[]

  profile                     Profile?
  posts                       Post[]
  likes                       Like[]
  comments                    Comment[]
  followers                   Follow[]              @relation("Following")
  following                   Follow[]              @relation("Follower")
  pinnedPostId                String?               @unique
  pinnedPost                  Post?                 @relation("PinnedPost", fields: [pinnedPostId], references: [id], onDelete: SetNull)
  notifications               Notification[]
  financeWorkspaces           BudgetWorkspace[]
  workspaceMemberships        WorkspaceMember[]
  householdInvitationsCreated HouseholdInvitation[] @relation("HouseholdInvitationCreator")
  bankConnections             BankConnection[]
  billingSubscription         BillingSubscription?

  @@unique([email])
  @@map("user")
}

model BillingSubscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("none")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
}

enum FinanceAccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH
  LOAN
  INVESTMENT
  OTHER
}

enum FinanceConnectionProvider {
  DEMO
  SIMPLEFIN
  GOCARDLESS
  ENABLE_BANKING
  OPEN_BANKING_IO
  PLAID
}

enum FinanceConnectionStatus {
  NOT_CONNECTED
  CONNECTED
  SYNCING
  NEEDS_RECONNECT
  FAILED
  DISABLED
}

enum FinanceTransactionStatus {
  CLEARED
  PENDING
  NEEDS_REVIEW
}

enum FinanceRecurringCadence {
  WEEKLY
  MONTHLY
  YEARLY
}

enum FinanceSyncStatus {
  SUCCESS
  FAILED
  RUNNING
}

enum HouseholdRole {
  OWNER
  MEMBER
}

enum HouseholdInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model BudgetWorkspace {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("Personal budget")
  currency  String   @default("USD")
  demo      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts          FinancialAccount[]
  categories        TransactionCategory[]
  merchants         Merchant[]
  budgetMonths      BudgetMonth[]
  transactions      FinanceTransaction[]
  recurringPayments RecurringPayment[]
  insights          MoneyInsight[]
  rules             CategoryRule[]
  syncRuns          SyncRun[]
  members           WorkspaceMember[]
  invitations       HouseholdInvitation[]
  bankConnections   BankConnection[]

  @@index([userId])
}

model BankConnection {
  id             String                    @id @default(cuid())
  userId         String
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId    String
  workspace      BudgetWorkspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider       FinanceConnectionProvider
  providerItemId String?
  tokenRef       String?
  status         FinanceConnectionStatus   @default(NOT_CONNECTED)
  lastSyncedAt   DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  accounts FinancialAccount[]
  syncRuns SyncRun[]

  @@unique([provider, providerItemId])
  @@index([userId])
  @@index([workspaceId])
}

model FinancialAccount {
  id                String             @id @default(cuid())
  workspaceId       String
  workspace         BudgetWorkspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bankConnectionId  String?
  bankConnection    BankConnection?    @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  providerAccountId String?
  name              String
  institution       String?
  type              FinanceAccountType
  currency          String             @default("USD")
  balanceMinor      Int
  lastSyncedAt      DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  transactions    FinanceTransaction[]
  ownershipShares AccountOwnership[]

  @@unique([bankConnectionId, providerAccountId])
  @@index([workspaceId])
  @@index([bankConnectionId])
}

model WorkspaceMember {
  id                        String          @id @default(cuid())
  workspaceId               String
  workspace                 BudgetWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                      HouseholdRole   @default(MEMBER)
  householdShareBasisPoints Int             @default(10000)
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  accountOwnerships AccountOwnership[]

  @@unique([workspaceId, userId])
  @@index([userId])
}

model HouseholdInvitation {
  id              String                    @id @default(cuid())
  workspaceId     String
  workspace       BudgetWorkspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email           String
  tokenHash       String                    @unique
  role            HouseholdRole             @default(MEMBER)
  status          HouseholdInvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdByUserId String
  createdBy       User                      @relation("HouseholdInvitationCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([workspaceId, status])
  @@index([email, status])
}

model AccountOwnership {
  id               String           @id @default(cuid())
  accountId        String
  account          FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  memberId         String
  member           WorkspaceMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  shareBasisPoints Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([accountId, memberId])
  @@index([memberId])
}

model TransactionCategory {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   BudgetWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  system      Boolean         @default(false)
  color       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  transactions      FinanceTransaction[]
  allocations       BudgetAllocation[]
  recurringPayments RecurringPayment[]
  rules             CategoryRule[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Merchant {
  id             String          @id @default(cuid())
  workspaceId    String
  workspace      BudgetWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  transactions      FinanceTransaction[]
  recurringPayments RecurringPayment[]
  rules             CategoryRule[]

  @@unique([workspaceId, normalizedName])
  @@index([workspaceId])
}

model FinanceTransaction {
  id                    String                   @id @default(cuid())
  workspaceId           String
  workspace             BudgetWorkspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId             String
  account               FinancialAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId            String?
  category              TransactionCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  merchantId            String?
  merchant              Merchant?                @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  providerTransactionId String?
  postedAt              DateTime
  description           String
  amountMinor           Int
  currency              String                   @default("USD")
  status                FinanceTransactionStatus @default(CLEARED)
  recurring             Boolean                  @default(false)
  notes                 String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([accountId, providerTransactionId])
  @@index([workspaceId, postedAt])
  @@index([accountId])
  @@index([categoryId])
}

model BudgetMonth {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   BudgetWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  month       String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  allocations BudgetAllocation[]

  @@unique([workspaceId, month])
  @@index([workspaceId])
}

model BudgetAllocation {
  id             String              @id @default(cuid())
  budgetMonthId  String
  budgetMonth    BudgetMonth         @relation(fields: [budgetMonthId], references: [id], onDelete: Cascade)
  categoryId     String
  category       TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  allocatedMinor Int
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([budgetMonthId, categoryId])
  @@index([categoryId])
}

model RecurringPayment {
  id          String                  @id @default(cuid())
  workspaceId String
  workspace   BudgetWorkspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  merchantId  String?
  merchant    Merchant?               @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  categoryId  String?
  category    TransactionCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name        String
  amountMinor Int
  currency    String                  @default("USD")
  cadence     FinanceRecurringCadence
  nextDate    DateTime
  confirmed   Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([workspaceId])
  @@index([nextDate])
}

model SyncRun {
  id                String                    @id @default(cuid())
  workspaceId       String
  workspace         BudgetWorkspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bankConnectionId  String?
  bankConnection    BankConnection?           @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  provider          FinanceConnectionProvider
  status            FinanceSyncStatus
  startedAt         DateTime                  @default(now())
  finishedAt        DateTime?
  transactionsSeen  Int                       @default(0)
  transactionsAdded Int                       @default(0)
  errorCode         String?
  errorMessage      String?

  @@index([workspaceId, startedAt])
  @@index([bankConnectionId])
}

model MoneyInsight {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   BudgetWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  body        String
  severity    String          @default("info")
  createdAt   DateTime        @default(now())
  dismissedAt DateTime?

  @@index([workspaceId, createdAt])
}

model CategoryRule {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   BudgetWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  merchantId  String?
  merchant    Merchant?           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  matchText   String?
  categoryId  String
  category    TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([workspaceId])
  @@index([categoryId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username  String   @unique
  bio       String?
  field     Category @default(OTHER)
  headline  String?
  onboarded Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id           String    @id @default(cuid())
  title        String
  description  String?
  content      String    @db.Text
  category     Category
  kind         PostKind  @default(WORKFLOW)
  tools        String[]  @default([])
  authorId     String
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  pinnedBy     User?     @relation("PinnedPost")
  likes        Like[]
  comments     Comment[]
  forkedFromId String?
  forkedFrom   Post?     @relation("Forks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks        Post[]    @relation("Forks")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([kind])
  @@index([createdAt])
  @@index([authorId])
  @@index([forkedFromId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  postId    String
  authorId  String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([createdAt])
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  FORK
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  actorId   String
  postId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}
