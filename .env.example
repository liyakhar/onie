# Database (Railway Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/weavel"

# Better Auth
BETTER_AUTH_SECRET="change-me-to-a-long-random-string-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional — enables "Continue with Google" on /login)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Public site URL for SEO (canonical, OG, sitemap). Defaults to BETTER_AUTH_URL.
SITE_URL="http://localhost:3000"

# Google Search Console — HTML tag method (Search Console → Settings → Ownership verification)
# Adds <meta name="google-site-verification" content="…" /> and can generate public/google….html via pnpm seo:gsc
GOOGLE_SITE_VERIFICATION=""
