# Database (Railway Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/weavel"

# Better Auth
BETTER_AUTH_SECRET="change-me-to-a-long-random-string-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional — enables "Continue with Google" on /login)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Public site URL for SEO (canonical, OG, sitemap). Defaults to BETTER_AUTH_URL.
SITE_URL="http://localhost:3000"

# Pre-deploy SEO gate: pnpm seo:verify  (add -- --production in CI)

# DataForSEO — keyword volume/KD for keywords.csv (pay-as-you-go API)
# Get credentials: https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
# Google Search Console — HTML tag method (Search Console → Settings → Ownership verification)
# Adds <meta name="google-site-verification" content="…" /> and can generate public/google….html via pnpm seo:gsc
GOOGLE_SITE_VERIFICATION=""

# X API (outreach — personal founder account)
# developer.x.com → OAuth 2.0 user context
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_ACCESS_TOKEN=""
X_REFRESH_TOKEN=""
X_HANDLE=""

# OAuth callback for pnpm outreach:oauth (set same URL in X app settings)
X_OAUTH_PORT="4150"
X_OAUTH_REDIRECT="http://127.0.0.1:4150/callback"

# Optional — LLM polish for outreach drafts (pnpm outreach:draft)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
