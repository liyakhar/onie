# Database (Railway Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/weavel"

# Better Auth
BETTER_AUTH_SECRET="change-me-to-a-long-random-string-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional — enables "Continue with Google" on /login)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Public site URL for SEO (canonical, OG, sitemap). Defaults to BETTER_AUTH_URL.
SITE_URL="http://localhost:3000"

# Comma-separated founder/admin emails with free access to the private app.
FOUNDER_EMAILS=""

# Private staging only. Keep these unset locally and in paid production.
STAGING_ACCESS_USERNAME="wollie"
STAGING_ACCESS_PASSWORD=""
CLOUDFLARE_PAGES_PROJECT=""
# Must be a separate staging Hyperdrive binding, never production's binding.
CLOUDFLARE_HYPERDRIVE_ID=""

# Stripe Billing (use test-mode keys until the live launch checklist is complete)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_MONTHLY_PRICE_ID=""
STRIPE_YEARLY_PRICE_ID=""
# Set only after documenting the applicable VAT/tax position.
STRIPE_AUTOMATIC_TAX="false"
# Keep true in paid production. Private pre-company staging may set false until
# Stripe's legal business profile can hold the public Terms URL.
STRIPE_CHECKOUT_TERMS_CONSENT="true"

# Transactional account email (password resets, invites, and security notices)
# Free launch option: Brevo transactional email API. Resend remains supported.
BREVO_API_KEY=""
RESEND_API_KEY=""
EMAIL_FROM="Wollie <account@example.com>"

# Public legal identity. Complete these before any paid production launch.
LEGAL_BUSINESS_NAME=""
LEGAL_BUSINESS_FORM=""
LEGAL_BUSINESS_ADDRESS=""
LEGAL_REGISTRATION_NUMBER=""
LEGAL_CONTACT_EMAIL=""
LEGAL_CONTACT_PHONE=""
LEGAL_PUBLICATION_DIRECTOR=""
LEGAL_HOST_NAME="Cloudflare, Inc."
LEGAL_HOST_ADDRESS="101 Townsend St, San Francisco, CA 94107, USA"
# Confirm the competent qualified entity for the final activities.
CONSUMER_MEDIATOR_NAME="Service de Médiation pour le Consommateur"
CONSUMER_MEDIATOR_URL="https://mediationconsommateur.be/"
PUBLIC_DOMAIN_VERIFIED="false"
LEGAL_LAUNCH_FACTS_CONFIRMED="false"
TAX_LAUNCH_POSITION_CONFIRMED="false"

# Wollie bank sync (optional until live launch)
# User bank credentials bundles are encrypted server-side with this key.
ENABLE_LIVE_BANK_SYNC="false"
BANK_SYNC_ENCRYPTION_KEY=""
# Legacy North American provider support
SIMPLEFIN_ACCESS_URL=""
SIMPLEFIN_LOOKBACK_DAYS="90"
# Direct European bank sync (https://enablebanking.com/cp)
# Create a sandbox app first. Use "production" only for a contracted app or
# restricted testing with your own whitelisted accounts.
ENABLE_BANKING_ENVIRONMENT="sandbox"
ENABLE_BANKING_PUBLIC_ACCESS_APPROVED="false"
ENABLE_BANKING_APPLICATION_ID=""
# PKCS#8 PEM. In hosted environments, store line breaks as \n.
ENABLE_BANKING_PRIVATE_KEY=""
ENABLE_BANKING_REDIRECT_URL="http://localhost:3000/app/accounts"

# Pre-deploy SEO gate: pnpm seo:verify  (add -- --production in CI)

# DataForSEO — keyword volume/KD for keywords.csv (pay-as-you-go API)
# Get credentials: https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
# Google Search Console — HTML tag method (Search Console → Settings → Ownership verification)
# Adds <meta name="google-site-verification" content="…" /> and can generate public/google….html via pnpm seo:gsc
GOOGLE_SITE_VERIFICATION=""

# X API (outreach — personal founder account)
# developer.x.com → OAuth 2.0 user context
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_ACCESS_TOKEN=""
X_REFRESH_TOKEN=""
X_HANDLE=""

# OAuth callback for pnpm outreach:oauth (set same URL in X app settings)
X_OAUTH_PORT="4150"
X_OAUTH_REDIRECT="http://127.0.0.1:4150/callback"

# Optional — LLM polish for outreach drafts (pnpm outreach:draft)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
