# Copy to .env.staging locally. Never commit the filled file.
DATABASE_URL="postgresql://separate-staging-database"
BETTER_AUTH_SECRET="at-least-32-random-characters"
BETTER_AUTH_URL="https://wollie-staging.example.pages.dev"
SITE_URL="https://wollie-staging.example.pages.dev"

STAGING_ACCESS_USERNAME="wollie"
STAGING_ACCESS_PASSWORD="at-least-20-random-characters"
CLOUDFLARE_PAGES_PROJECT="wollie-staging"
CLOUDFLARE_HYPERDRIVE_ID="separate-staging-hyperdrive-id"

# Test and sandbox only.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_MONTHLY_PRICE_ID=""
STRIPE_YEARLY_PRICE_ID=""
STRIPE_AUTOMATIC_TAX="false"
ENABLE_LIVE_BANK_SYNC="true"
BANK_SYNC_ENCRYPTION_KEY="at-least-32-random-characters-different-from-production"
ENABLE_BANKING_ENVIRONMENT="sandbox"
ENABLE_BANKING_PUBLIC_ACCESS_APPROVED="false"
ENABLE_BANKING_APPLICATION_ID=""
ENABLE_BANKING_PRIVATE_KEY=""
ENABLE_BANKING_REDIRECT_URL="https://wollie-staging.example.pages.dev/app/accounts"

RESEND_API_KEY=""
EMAIL_FROM="Wollie staging <account@verified-staging-domain.example>"
LEGAL_LAUNCH_FACTS_CONFIRMED="false"
TAX_LAUNCH_POSITION_CONFIRMED="false"
