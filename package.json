{
  "name": "weavel",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.12.0"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "build:cf": "NITRO_PRESET=cloudflare_pages vite build && node scripts/patch-prisma-cloudflare.mjs",
    "preview": "vite preview",
    "preview:cf": "pnpm build:cf && npx wrangler pages dev dist",
    "preflight:prod": "node scripts/preflight-prod.mjs",
    "deploy:check": "pnpm preflight:prod && pnpm build:cf",
    "deploy": "pnpm build:cf && npx wrangler pages deploy dist --project-name=onie",
    "test": "vitest run",
    "post-cta-init": "npx -y create-db@latest --user-agent tanstack/tsrouter",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:diff:prod": "prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --script",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "start": "node .output/server/index.mjs",
    "seo:og-images": "python3 scripts/generate-og-images.py",
    "seo:gsc": "dotenv -e .env.local -- python3 scripts/write-gsc-verification.py",
    "seo:keywords": "dotenv -e .env.local -- node scripts/fetch-keywords-dataforseo.mjs",
    "seo:keywords:clean": "node scripts/cleanup-keywords.mjs",
    "blog:next": "node scripts/next-blog-keyword.mjs",
    "seo:verify": "dotenv -e .env.local -- tsx scripts/verify-seo.ts",
    "seo:lighthouse": "dotenv -e .env.local -- node scripts/lighthouse-audit.mjs",
    "outreach:check": "dotenv -e .env.local -- node scripts/outreach/check-env.mjs",
    "outreach:draft": "dotenv -e .env.local -- node scripts/outreach/draft.mjs",
    "outreach:review": "node scripts/outreach/review.mjs",
    "outreach:send": "dotenv -e .env.local -- node scripts/outreach/send.mjs",
    "outreach:oauth": "dotenv -e .env.local -- node scripts/outreach/oauth.mjs",
    "outreach:fetch": "dotenv -e .env.local -- node scripts/outreach/fetch.mjs",
    "outreach:discover": "dotenv -e .env.local -- node scripts/outreach/discover.mjs",
    "outreach:batch": "dotenv -e .env.local -- node scripts/outreach/batch.mjs",
    "outreach:feed": "dotenv -e .env.local -- node scripts/outreach/feed.mjs",
    "outreach:copy": "node scripts/outreach/copy.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@latest",
    "pg": "^8.16.0",
    "prisma": "^7.4.2",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unwasm": "^0.5.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "prisma",
      "@prisma/engines"
    ]
  }
}
